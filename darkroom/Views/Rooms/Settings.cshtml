@model RoomSettingsVm
@{
    ViewData["Title"] = "房间设置";
}

<div class="d-flex align-items-center justify-content-between gap-2 mb-3">
    <h1 class="h4 mb-0">房间设置</h1>
    <a class="btn btn-outline-secondary btn-sm" asp-action="Room" asp-route-id="@Model.RoomId">返回</a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Settings" method="post" enctype="multipart/form-data" class="vstack gap-3">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="RoomId" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="d-flex gap-3 align-items-center">
                <img class="rounded border room-avatar" src="@(string.IsNullOrWhiteSpace(Model.CurrentAvatarUrl) ? "/img/room-default.svg" : Model.CurrentAvatarUrl)" alt="当前头像" />
                <div class="flex-grow-1">
                    <label class="form-label" asp-for="Avatar">更换头像</label>
                    <input class="form-control" asp-for="Avatar" type="file" accept=".png,.jpg,.jpeg,.webp,image/*" />
                    <span class="text-danger" asp-validation-for="Avatar"></span>
                </div>
            </div>

            <div>
                <label class="form-label" asp-for="Name">房间名</label>
                <input class="form-control" asp-for="Name" maxlength="50" />
                <span class="text-danger" asp-validation-for="Name"></span>
            </div>

            <div>
                <label class="form-label" asp-for="MaxMembers">人数上限</label>
                <input class="form-control" asp-for="MaxMembers" type="number" min="2" max="50" />
                <span class="text-danger" asp-validation-for="MaxMembers"></span>
            </div>

            <div class="row g-2">
                <div class="col-12 col-md-6">
                    <label class="form-label" asp-for="NewPassword">设置新密码（可选）</label>
                    <input class="form-control" asp-for="NewPassword" type="password" autocomplete="new-password" maxlength="50" />
                    <span class="text-danger" asp-validation-for="NewPassword"></span>
                </div>
                <div class="col-12 col-md-6 d-flex align-items-end">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="RemovePassword" type="checkbox" />
                        <label class="form-check-label" asp-for="RemovePassword">移除密码</label>
                    </div>
                </div>
            </div>

            <div class="d-grid">
                <button class="btn btn-primary" type="submit">保存</button>
            </div>
        </form>

        <hr class="my-4" />

        <div class="alert alert-danger small mb-3">
            删除房间将同时删除聊天记录、管理员配置和头像文件（不可恢复）。
        </div>

        <form asp-action="Delete" method="post" onsubmit="return confirm('确定要删除该房间吗？此操作不可恢复。');">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.RoomId" />
            <div class="d-grid">
                <button class="btn btn-danger" type="submit">删除房间</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
